## Opacity Modifiers

Use Tailwind's opacity modifier for hover/active/disabled states:

```tsx
// Hover states
className="bg-primary hover:bg-primary/90"
className="bg-secondary hover:bg-secondary/80"

// Active states
className="bg-accent active:bg-accent/90"

// Disabled states
className="disabled:opacity-50"
className="disabled:bg-muted/50"
```

## Color Usage Patterns

### Button Variants

```tsx
const buttonVariants = cva("base-classes", {
  variants: {
    variant: {
      primary: "bg-primary text-primary-foreground hover:bg-primary/90",
      secondary: "bg-secondary text-secondary-foreground hover:bg-secondary/80",
      ghost: "hover:bg-accent hover:text-accent-foreground",
      outline: "border border-input bg-background hover:bg-accent hover:text-accent-foreground",
      destructive: "bg-destructive text-destructive-foreground hover:bg-destructive/90",
    },
  },
});
```

### Input Styles

```tsx
className="border border-input bg-background text-foreground placeholder:text-muted-foreground focus-visible:ring-ring"
```

### Card Styles

```tsx
className="bg-background border border-border rounded-[--radius]"
```

## Class Ordering

Follow this order for Tailwind classes:

1. **Layout**: `flex`, `grid`, `block`, `inline-flex`
2. **Positioning**: `relative`, `absolute`, `fixed`
3. **Display**: `hidden`, `inline`, `flex`
4. **Sizing**: `w-*`, `h-*`, `max-w-*`, `min-h-*`
5. **Spacing**: `m-*`, `p-*`, `space-*`, `gap-*`
6. **Typography**: `text-*`, `font-*`, `leading-*`
7. **Colors**: `bg-*`, `text-*`, `border-*`
8. **Borders**: `border`, `border-*`, `rounded-*`
9. **Effects**: `shadow-*`, `opacity-*`
10. **Transitions**: `transition-*`, `duration-*`
11. **States**: `hover:*`, `focus:*`, `active:*`, `disabled:*`

```tsx
// ✅ GOOD - Properly ordered
className="inline-flex items-center justify-center rounded-md px-4 py-2 text-sm font-medium bg-primary text-primary-foreground transition-colors hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:opacity-50"

// ❌ BAD - Random order
className="bg-primary hover:bg-primary/90 inline-flex text-primary-foreground px-4 disabled:opacity-50 rounded-md"
```

## Using cva with CSS Variables

### Basic Pattern

```tsx
import { cva, type VariantProps } from "class-variance-authority";

const componentVariants = cva(
  // Base classes - always applied
  "inline-flex items-center justify-center rounded-md font-medium transition-colors",
  {
    variants: {
      variant: {
        default: "bg-background text-foreground",
        primary: "bg-primary text-primary-foreground hover:bg-primary/90",
        secondary: "bg-secondary text-secondary-foreground hover:bg-secondary/80",
        ghost: "hover:bg-accent hover:text-accent-foreground",
        outline: "border border-input bg-background hover:bg-accent",
      },
      size: {
        sm: "h-9 px-3 text-sm",
        md: "h-10 px-4 py-2",
        lg: "h-11 px-8",
      },
    },
    defaultVariants: {
      variant: "default",
      size: "md",
    },
  }
);
```

### With Compound Variants

```tsx
const variants = cva("base-classes", {
  variants: {
    variant: {
      primary: "bg-primary",
      outline: "border border-input",
    },
    size: {
      sm: "text-sm",
      lg: "text-lg",
    },
  },
  compoundVariants: [
    {
      variant: "outline",
      size: "sm",
      className: "border-2", // Special case: small outline gets thicker border
    },
  ],
});
```

## The cn() Utility

Always use the `cn()` utility for merging classNames:

```tsx
import { cn } from "@/lib/utils";

// ✅ CORRECT - Uses cn() for merging
<div className={cn(baseVariants({ variant }), className)} />

// ❌ WRONG - Manual concatenation
<div className={`${baseVariants({ variant })} ${className}`} />
```

### cn() Implementation

```tsx
// src/lib/utils.ts
import { clsx, type ClassValue } from "clsx";
import { twMerge } from "tailwind-merge";

export function cn(...inputs: ClassValue[]) {
  return twMerge(clsx(inputs));
}
```

### cn() Usage Examples

```tsx
// Merge variants with custom className
<Button className={cn("custom-class", className)} />

// Conditional classes
<div className={cn("base-class", isActive && "active-class")} />

// Array of classes
<div className={cn(["class-1", "class-2", condition && "class-3"])} />
```

## Focus States

### Focus Visible Pattern

Use `focus-visible` for keyboard-only focus indicators:

```tsx
// ✅ CORRECT - Only shows on keyboard focus
className="focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"

// ❌ WRONG - Shows on mouse click too
className="focus:outline-none focus:ring-2 focus:ring-ring"
```

### Standard Focus Ring

```tsx
// Standard pattern for all interactive elements
className="focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background"
```

## Responsive Design (Post-v1)

v1 is desktop-only, but structure CSS for future responsive breakpoints:

```tsx
// Future pattern (not in v1)
className="flex flex-col md:flex-row gap-4 md:gap-6"
```

